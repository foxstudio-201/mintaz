{
  "name": "mintaz",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted Platform-as-a-Service for Git-based deployments",
  "license": "MIT",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "install:all": "npm --prefix backend install && npm --prefix frontend install",
    "build:web": "npm --prefix frontend run build",
    "db:init": "npm --prefix backend run db:init",
    "start": "npm --prefix backend run start",
    "dev:api": "npm --prefix backend run dev",
    "dev:web": "npm --prefix frontend run dev",
    "update": "bash update.sh"
  }
}
