# ── Mintaz — backend configuration ───────────────────────────────────

# HTTP
PORT=8080
HOST=0.0.0.0

# Public base domain. Apps are deployed under *.<BASE_DOMAIN>.
BASE_DOMAIN=your-domain.com
DASH_SUBDOMAIN=dash

# Auth
# REQUIRED: the server refuses to start with these placeholder values (unless
# ALLOW_INSECURE_DEFAULTS=1). Generate strong values, e.g. `openssl rand -hex 32`.
JWT_SECRET=change-me-to-a-long-random-string
TOKEN_TTL=7d
# Key used to encrypt stored 3rd-party tokens (Cloudflare/GitHub) at rest.
# Defaults to JWT_SECRET if unset; set separately to rotate keys independently.
# SECRET_KEY=
# Allow public self-registration. Set false to lock the instance to existing
# accounts (admin creates users). The first/bootstrap admin is always allowed.
ALLOW_REGISTRATION=true
# Comma-separated browser origins allowed via CORS. Empty reflects any origin
# (fine for local dev). In production set it to your dashboard URL(s).
# CORS_ORIGINS=https://dash.your-domain.com
# Escape hatch for throwaway local dev only — bypasses the insecure-default check.
# ALLOW_INSECURE_DEFAULTS=1

# Seed admin (used by `npm run db:init`). Use a strong password.
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=changeme

# Storage
DATA_DIR=./data
WORK_DIR=./workdir
DB_PATH=./data/mintaz.sqlite

# Frontend build to serve (relative to backend/). Leave empty in dev.
STATIC_DIR=../frontend/dist

# Database driver: sqlite (default) | mysql
DB_DRIVER=sqlite
# When DB_DRIVER=mysql (MariaDB/MySQL), set these (used by the data layer once
# MySQL support is wired in):
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=mintaz
# DB_USER=mintaz
# DB_PASSWORD=

# ── Redis (optional) ──────────────────────────────────────────────────────────
# Enables shared rate-limiting + caching across multiple instances. Leave unset
# to use in-process memory (fine for a single instance).
# REDIS_URL=redis://127.0.0.1:6379

# ── Docker ───────────────────────────────────────────────────────────────────
DOCKER_BIN=docker
# Host-port range allocated to deployed containers.
PORT_RANGE_START=21000
PORT_RANGE_END=21999
# Default restart policy for app containers: no | on-failure | always | unless-stopped
DEFAULT_RESTART_POLICY=unless-stopped
# Delete the build context + old containers of superseded deployments.
AUTO_CLEANUP=true

# ── Container isolation / resource caps (important for public instances) ──────
# Per-container hard limits — bound a single tenant's blast radius.
CONTAINER_MEMORY=512m
CONTAINER_CPUS=1.0
CONTAINER_PIDS_LIMIT=256
CONTAINER_NOFILE=1024
# Drop all Linux capabilities (keep only the minimal web-server set). Off by
# default; enable once you've confirmed your deployments still start.
CONTAINER_DROP_CAPS=false
# RAM cap for the build step.
BUILD_MEMORY=2g
# Block container-to-container traffic on the shared bridge (tenant isolation).
# Applies to a freshly created network; recreate an existing `mintaz` network to
# adopt it (stop containers, `docker network rm mintaz`).
DISABLE_INTER_CONTAINER=true

# ── Reverse proxy ─────────────────────────────────────────────────────────────
# caddy | nginx
PROXY=caddy
# Port Mintaz's own reverse proxy listens on. The Cloudflare tunnel forwards
# *.<domain> here. Kept off :80 so it won't clash with any existing web server.
PROXY_HTTP_PORT=8088
# Built-in Node reverse proxy (routes *.<domain> by Host → containers). When
# true (default) you do NOT need Caddy/Nginx — just point the tunnel at
# *.<domain> → http://localhost:8088. Set false to front with Caddy/Nginx.
BUILTIN_PROXY=true
# File the API regenerates with all active routes.
CADDY_SNIPPET=/etc/caddy/mintaz.routes.caddy
CADDY_RELOAD_CMD=sudo systemctl reload caddy
NGINX_SNIPPET=/etc/nginx/conf.d/mintaz.conf
NGINX_RELOAD_CMD=sudo systemctl reload nginx

# ── GitHub webhooks ───────────────────────────────────────────────────────────
# Global fallback secret; each project can also have its own.
GITHUB_WEBHOOK_SECRET=change-me-webhook-secret

# Global fallback token for cloning PRIVATE repos over HTTPS (a GitHub
# Personal Access Token with `repo` scope). Each project can override this with
# its own token in the dashboard. Leave blank for public repos only.
GITHUB_TOKEN=

# ── GitHub OAuth App (optional — enables "Connect GitHub" + repo import) ───────
# Create one at https://github.com/settings/developers (New OAuth App).
#   Homepage URL:        https://dash.<domain>     (dev: http://localhost:5173)
#   Authorization callback URL: <PUBLIC_URL>/api/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Public URL the browser uses (for the OAuth redirect). Prod defaults to the
# dashboard URL; in dev set it to the Vite origin so the callback resolves.
# PUBLIC_URL=http://localhost:5173

# ── Cloudflare ────────────────────────────────────────────────────────────────
CF_TUNNEL_NAME=mintaz-tunnel
